# frontend
FRONTEND_PORT=3300
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
KMS_API_BASE_URL=http://localhost:8000/api/v1
KMS_AUTH_COOKIE_SECURE=false

# backend
APP_NAME=KMS API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=5
LOGIN_LOCK_STEP_MINUTES=5
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3300,http://127.0.0.1:3300
# 生产环境必须改为强随机 SECRET_KEY，并替换为真实业务域名白名单（不可保留 localhost 默认值）
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=kms
MYSQL_USER=kms
MYSQL_PASSWORD=kms
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200
QDRANT_URL=http://qdrant:6333
QDRANT_HOST_PORT=16333
QDRANT_COLLECTION=kms_chunks
QDRANT_TIMEOUT_SECONDS=15
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kms-files
MINIO_SECURE=false
GEMINI_API_KEY=
QA_RECALL_TOP_K=8
QA_SOURCE_TOP_N=5
QA_CONTEXT_CHAR_BUDGET=7000
QA_CONTEXT_MAX_CHUNKS_PER_NOTE=2
QA_CHAT_BASE_URL=
QA_CHAT_MODEL_NAME=
QA_CHAT_API_KEY=
QA_CHAT_TIMEOUT_SECONDS=30
QA_CHAT_MAX_TOKENS=
QA_EMBED_BASE_URL=http://embedding-service:8001
QA_EMBED_MODEL_NAME=BAAI/bge-m3
QA_EMBED_API_KEY=
QA_EMBED_TIMEOUT_SECONDS=30
QA_SYSTEM_PROMPT_DEFAULT=You are an enterprise knowledge assistant. Answer only from provided sources. If sources are insufficient, say you cannot answer from available content.
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_LOCAL_MODEL_DIR=
EMBEDDING_DEVICE=cuda
EMBEDDING_USE_FP16=true
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_LENGTH=2048
EMBEDDING_CACHE_DIR=
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1
DEMO_AUTH_ENABLED=true
